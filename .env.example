# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps Platform integrations (rendering interactive maps, routes, and place search).
# Add your key under Settings (gear icon in the top right) -> Secrets.
GOOGLE_MAPS_PLATFORM_KEY=""

# WOOCOMMERCE_API_URL: Your WordPress/WooCommerce site base URL (e.g., https://example.com)
WOOCOMMERCE_API_URL=""

# WOOCOMMERCE_CONSUMER_KEY: WooCommerce API Consumer Key (e.g., ck_...)
WOOCOMMERCE_CONSUMER_KEY=""

# WOOCOMMERCE_CONSUMER_SECRET: WooCommerce API Consumer Secret (e.g., cs_...)
WOOCOMMERCE_CONSUMER_SECRET=""

# SUPABASE_URL: Your Supabase project URL (e.g., https://your-project.supabase.co)
SUPABASE_URL="https://your-project.supabase.co"

# SUPABASE_ANON_KEY: Your Supabase anon/public client API key
SUPABASE_ANON_KEY="your-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: Required for secure, privileged server-side database operations in api/_app.ts
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# JWT_SECRET: Secure secret string used to sign session cookies and JWT tokens for logged-in technicians
JWT_SECRET="your-jwt-secret-key-change-me"
